{
    "name": "doctor-skripnikova/viktoria-site",
    "description": "Сайт доктора Скрипниковой Виктории PHP API",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "twig/twig": "^3.11",
        "symfony/http-foundation": "^6.4",
        "nikic/fast-route": "^1.3"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    }
}
