{% extends 'base.html.twig' %}

{% block body %}
<section class="py-5 section-muted">
    <div class="container">
        <div class="row align-items-center g-4 g-lg-5">
            <div class="col-lg-6 order-lg-2">
                <div class="photo-square ms-lg-auto">
                    <img class="hero-photo" src="/images/viktoria-2.jpg" width="560" height="560" alt="Виктория Скрипникова" loading="eager">
                </div>
            </div>
            <div class="col-lg-6 order-lg-1">
                <span class="tag-pill mb-3"><i class="bi bi-stars"></i> Эстетическая медицина</span>
                <h1 class="display-5 fw-bold mb-3" style="letter-spacing: -0.03em;">Виктория Скрипникова</h1>
                <p class="lead text-muted mb-4">Врач-ординатор дерматолог, косметолог. Подбор процедур под ваш тип кожи и задачи: натуральный результат без «перегруза».</p>
                <div class="d-flex flex-wrap gap-2 mb-4">
                    <a class="btn btn-accent btn-lg" href="/contact">Запись на приём</a>
                    <a class="btn btn-outline-accent btn-lg" href="/about">О враче</a>
                </div>
                <p class="small text-muted mb-0"><i class="bi bi-shield-check text-accent me-1"></i> Конфиденциальность и безопасные протоколы</p>
            </div>
        </div>
    </div>
</section>

<div class="container py-5">
    <div class="row justify-content-center mb-5">
        <div class="col-lg-8 text-center">
            <h2 class="fw-bold mb-3">Доказательная дерматология<br> и безопасная косметология</h2>
            <p class="text-muted mb-0">Акцент на здоровом виде кожи, мягких объёмах и предсказуемом эффекте. Обсуждаем ожидания и выбираем только то, что действительно уместно.</p>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card-soft p-4 h-100">
                <div class="text-accent mb-2"><i class="bi bi-droplet" style="font-size: 1.75rem;"></i></div>
                <h3 class="h5 fw-semibold">Индивидуально</h3>
                <p class="text-muted small mb-0">Оценка состояния кожи и план процедур без шаблонных решений.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-soft p-4 h-100">
                <div class="text-accent mb-2"><i class="bi bi-bandaid" style="font-size: 1.75rem;"></i></div>
                <h3 class="h5 fw-semibold">Аккуратно</h3>
                <p class="text-muted small mb-0">Работа в комфортном темпе, объяснение этапов и ухода после визита.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card-soft p-4 h-100">
                <div class="text-accent mb-2"><i class="bi bi-chat-heart" style="font-size: 1.75rem;"></i></div>
                <h3 class="h5 fw-semibold">На связи</h3>
                <p class="text-muted small mb-0">Ответы на вопросы после процедуры и поддержка по рекомендациям.</p>
            </div>
        </div>
    </div>
</div>

<section class="py-5" style="background: linear-gradient(180deg, var(--ds-beige) 0%, var(--ds-bg) 100%);">
    <div class="container">
        <div class="row g-4 align-items-center">
            <div class="col-lg-6">
                <h2 class="fw-bold mb-3 d-flex align-items-center gap-2 flex-wrap">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="text-accent flex-shrink-0" style="width: 1.75rem; height: 1.75rem;" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25zM6.75 12h.008v.008H6.75V12zm0 3h.008v.008H6.75V15zm0 3h.008v.008H6.75V18z" />
                    </svg>
                    <span>С какими запросами работаю</span>
                </h2>
                <ul class="list-unstyled text-muted mb-0">
                    <li class="mb-2"><i class="bi bi-check2-circle text-accent me-2"></i> Консультация по разбору домашнего ухода</li>
                    <li class="mb-2"><i class="bi bi-check2-circle text-accent me-2"></i> Ведение пациентов с акне и розацеа</li>
                    <li class="mb-2"><i class="bi bi-check2-circle text-accent me-2"></i> Аппаратная косметология</li>
                    <li class="mb-2"><i class="bi bi-check2-circle text-accent me-2"></i> Инъекционные процедуры</li>
                    <li class="mb-2"><i class="bi bi-check2-circle text-accent me-2"></i> Лечение гиперпигментации, купероза, рубцов постакне</li>
                    <li class="mb-2"><i class="bi bi-check2-circle text-accent me-2"></i> Подготовка и реабилитация после пластических операций</li>
                </ul>
            </div>
            <div class="col-lg-6">
                <div class="card-soft p-4 p-md-5">
                    <h3 class="h5 fw-semibold mb-2">Коротко о подходе</h3>
                    <p class="text-muted small mb-0">Сначала — диалог и безопасность, затем — процедура. Никаких лишних обещаний: только честная оценка того, что можно улучшить и чего лучше избежать.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="request" class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="text-center mb-4">
                    <h2 class="fw-bold">Запись на приём</h2>
                    <p class="text-muted mb-0">Оставьте контакты — я отвечу и предложу удобное время. Поля со звёздочкой обязательны.</p>
                </div>
                <div class="card-soft p-4 p-md-5">
                    <form class="js-lead-form" autocomplete="on">
                        <input type="hidden" name="form_source" value="index">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label" for="l_name">Имя *</label>
                                <input class="form-control" type="text" id="l_name" name="name" required placeholder="Как к вам обращаться">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label" for="l_phone">Телефон *</label>
                                <input class="form-control" type="tel" id="l_phone" name="phone" required placeholder="+7 …">
                            </div>
                            <div class="col-12">
                                <label class="form-label" for="l_email">Email</label>
                                <input class="form-control" type="email" id="l_email" name="email" placeholder="Необязательно">
                            </div>
                            <div class="col-12">
                                <label class="form-label" for="l_subject">Тема</label>
                                <select class="form-select" id="l_subject" name="subject">
                                    <option value="">Выберите вариант</option>
                                    <option value="consult">Консультация</option>
                                    <option value="inject">Инъекционные процедуры</option>
                                    <option value="care">Уход и косметика</option>
                                    <option value="other">Другое</option>
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label" for="l_message">Комментарий *</label>
                                <textarea class="form-control" id="l_message" name="message" rows="4" required placeholder="Кратко опишите запрос или удобное время связи"></textarea>
                            </div>
                            <div class="col-12">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="l_privacy" name="privacy" required>
                                    <label class="form-check-label small" for="l_privacy">Согласен(на) на обработку персональных данных *</label>
                                </div>
                            </div>
                            <div class="col-12 d-grid">
                                <button type="submit" class="btn btn-accent btn-lg"><i class="bi bi-send me-2"></i>Отправить</button>
                            </div>
                        </div>
                        <div class="js-form-result mt-3"></div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}
