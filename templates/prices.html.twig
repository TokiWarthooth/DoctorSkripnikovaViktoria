{% extends 'base.html.twig' %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 text-center mb-4">
            <span class="tag-pill mb-3"><i class="bi bi-currency-exchange"></i> Прайс</span>
            <h1 class="fw-bold mb-3">Стоимость услуг</h1>
            <p class="text-muted mb-0">Актуальные цены. Формат приёма можно уточнить при записи.</p>
        </div>
    </div>

    <div class="row justify-content-center mb-4">
        <div class="col-lg-10">
            <div class="card-soft p-4 border-0 d-flex align-items-start gap-3" style="background: linear-gradient(135deg, var(--ds-accent-soft) 0%, var(--ds-rose) 100%); border: 1px solid var(--ds-border) !important;">
                <div class="flex-shrink-0 text-accent pt-1"><i class="bi bi-gift fs-4"></i></div>
                <div>
                    <div class="fw-semibold text-dark mb-1">В день проведения процедуры консультация бесплатно</div>
                    <p class="small text-muted mb-0">Условие действует при записи на процедуру на выбранный день.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-lg-10">
            <h2 class="h5 fw-semibold mb-3 text-dark">Консультации</h2>
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card-soft p-4 h-100 d-flex flex-column">
                        <h3 class="h6 fw-semibold mb-2">Первичная консультация по ведению акне</h3>
                        <p class="text-muted small mb-0 flex-grow-1">Онлайн или очный приём — по договорённости.</p>
                        <div class="mt-3 fs-5 fw-bold text-accent">4&nbsp;000&nbsp;<span class="fs-6 fw-semibold">₽</span></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card-soft p-4 h-100 d-flex flex-column">
                        <h3 class="h6 fw-semibold mb-2">Повторные консультации по ведению акне</h3>
                        <p class="text-muted small mb-0 flex-grow-1">Сопровождение терапии и коррекция плана.</p>
                        <div class="mt-3 fs-5 fw-bold text-accent">3&nbsp;000&nbsp;<span class="fs-6 fw-semibold">₽</span></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card-soft p-4 h-100 d-flex flex-column">
                        <h3 class="h6 fw-semibold mb-2">Консультация по подбору домашнего ухода</h3>
                        <p class="text-muted small mb-0 flex-grow-1">Онлайн или очно.</p>
                        <div class="mt-3 fs-5 fw-bold text-accent">3&nbsp;000&nbsp;<span class="fs-6 fw-semibold">₽</span></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card-soft p-4 h-100 d-flex flex-column">
                        <h3 class="h6 fw-semibold mb-2">Консультация врача-дерматолога</h3>
                        <p class="text-muted small mb-0 flex-grow-1">Длительность приёма — 60 минут.</p>
                        <div class="mt-3 fs-5 fw-bold text-accent">3&nbsp;500&nbsp;<span class="fs-6 fw-semibold">₽</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-lg-10">
            <h2 class="h5 fw-semibold mb-3 text-dark">Чистки</h2>
            <div class="row g-4">
                <div class="col-md-6 col-lg-4">
                    <div class="card-soft p-4 h-100 d-flex flex-column">
                        <h3 class="h6 fw-semibold mb-2">Комбинированная чистка</h3>
                        <div class="mt-auto fs-5 fw-bold text-accent">4&nbsp;500&nbsp;<span class="fs-6 fw-semibold">₽</span></div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card-soft p-4 h-100 d-flex flex-column">
                        <h3 class="h6 fw-semibold mb-2">Ультразвуковая чистка</h3>
                        <div class="mt-auto fs-5 fw-bold text-accent">4&nbsp;000&nbsp;<span class="fs-6 fw-semibold">₽</span></div>
                    </div>
                </div>
                <div class="col-md-6 col-lg-4">
                    <div class="card-soft p-4 h-100 d-flex flex-column">
                        <h3 class="h6 fw-semibold mb-2">Механическая чистка</h3>
                        <div class="mt-auto fs-5 fw-bold text-accent">3&nbsp;500&nbsp;<span class="fs-6 fw-semibold">₽</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-lg-10">
            <h2 class="h5 fw-semibold mb-3 text-dark">Пилинги</h2>
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card-soft p-4 h-100 d-flex flex-column">
                        <h3 class="h6 fw-semibold mb-2">Азелаиновый пилинг</h3>
                        <div class="mt-auto fs-5 fw-bold text-accent">4&nbsp;000&nbsp;<span class="fs-6 fw-semibold">₽</span></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card-soft p-4 h-100 d-flex flex-column">
                        <h3 class="h6 fw-semibold mb-2">Азелаиновый пилинг с маской</h3>
                        <div class="mt-auto fs-5 fw-bold text-accent">4&nbsp;500&nbsp;<span class="fs-6 fw-semibold">₽</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8 text-center">
            <p class="text-muted small mb-3">Точную стоимость и доступные даты уточняйте при записи.</p>
            <a class="btn btn-accent btn-lg" href="/contact">Запись на приём</a>
        </div>
    </div>
</div>
{% endblock %}
